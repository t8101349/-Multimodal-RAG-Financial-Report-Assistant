# ===========================================================
# 多模態 RAG 財報助手 - 環境變數範本
# 使用方式：複製為 .env 後填入實際值
# ===========================================================

# --- OpenAI 相容 VLM 端點（必填）---
# DashScope 範例：https://dashscope.aliyuncs.com/compatible-mode/v1
# 本地 vLLM 範例：http://localhost:8000/v1
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_API_KEY=sk-your-key-here
VLM_MODEL=qwen2.5-vl-72b-instruct

# --- 視覺檢索後端偏好（byaldi / clip / auto）---
RETRIEVER_BACKEND=auto

# --- ColPali 本地模型路徑（若使用 Byaldi 路徑）---
COLPALI_MODEL_PATH=./models/colpali-v1.2-merged
COLPALI_INDEX_NAME=finance_report

# --- CLIP 模型（備援用）---
CLIP_MODEL_NAME=openai/clip-vit-base-patch32

# --- HuggingFace 鏡像（中國地區用）---
HF_HUB_OFFLINE=0
HF_ENDPOINT=https://hf-mirror.com

# --- 預設檢索參數 ---
RETRIEVAL_TOP_K=4
PAGE_RENDER_DPI=200
